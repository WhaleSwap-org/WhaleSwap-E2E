# Optional overrides for whaleswap-e2e.
# Defaults are already committed in e2e.config.ts, so this file is not required.

# WhaleSwap UI under test
BASE_URL=http://127.0.0.1:8080

# Chain/query selection used by UI URL
CHAIN_QUERY=local

# Hardhat-backed mock wallet configuration
MOCK_WALLET_RPC_URL=http://127.0.0.1:8545
MOCK_WALLET_CHAIN_ID=0x539
MOCK_WALLET_ACCOUNT=0x70997970c51812dc3a010c7d01b50e0d17dc79c8

# Optional alias used by some scripts/older configs
HARDHAT_RPC_URL=http://127.0.0.1:8545

# Optional Playwright mode
HEADLESS=false
