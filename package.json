{
  "name": "whaleswap-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end tests for WhaleSwap UI using Playwright with a Hardhat-backed mock wallet",
  "type": "module",
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:headless": "HEADLESS=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:local": "bash ./scripts/run-local-e2e.sh"
  },
  "devDependencies": {
    "@playwright/test": "1.48.2",
    "@types/node": "^25.3.0",
    "dotenv": "^16.6.1",
    "typescript": "^5.9.3"
  }
}
